# pdfmux4obsidian — API keys template
# Copy to .env and fill in your key(s).
# Only the key for your chosen LLM provider is needed.
# The Obsidian plugin stores the key in its settings instead — use .env for CLI mode.

GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Ollama runs locally — no key needed
